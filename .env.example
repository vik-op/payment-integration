# --- Payment Gateway Credentials ---
# Use sandbox/test keys from your provider (Stripe, Braintree, etc.)
GATEWAY_PUBLIC_KEY=pk_test_your_key_here
GATEWAY_SECRET_KEY=sk_test_your_key_here

# --- Webhook Security ---
# Secret used to verify HMAC signatures of incoming notifications
WEBHOOK_SIGNING_SECRET=whsec_your_secret_here

# --- App Configuration ---
APP_ENV=development
APP_DEBUG=true
LOG_CHANNEL=stack

# --- Database (if applicable) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=payment_demo
DB_USERNAME=root
DB_PASSWORD=
